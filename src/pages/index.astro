---
import BaseLayout from '../layouts/BaseLayout.astro';

const timeline = [
  { period: '2025 — н.в.', role: 'Devrel lead', company: 'ecom.tech' },
  { period: '2022–2024', role: 'Devrel', company: 'Самокат → samokat.tech → ecom.tech' },
  { period: '2017–2024', role: 'Сооснователь', company: 'Деврел-бюро' },
  { period: '2014–2017', role: 'Организатор', company: 'CodeFest — крупнейшая за Уралом ИТ-конференция' },
  { period: '2013–2016', role: 'Devrel', company: '2ГИС' },
  { period: 'до 2013', role: 'Фронтенд-разработчик', company: '' },
];

const contacts = [
  { label: 'Личный Telegram', value: '@mrmixsun', href: 'https://t.me/mrmixsun' },
  { label: 'Рабочий ТГ-канал', value: '@iamdevrel', href: 'https://t.me/iamdevrel' },
  { label: 'Сайт', value: 'iamdevrel.ru', href: 'https://iamdevrel.ru' },
  { label: 'GitHub', value: 'github.com/mrmixsun', href: 'https://github.com/mrmixsun' },
  { label: 'Телефон', value: '+7 913 391-95-37', href: 'tel:+79133919537' },
];
---

<BaseLayout title="Михаил Сторожилов" description="Devrel lead в ecom.tech. Developer Relations с 2013 года." singlePage={true}>
  <section id="hero" class="hero">
    <div class="hero-photo">
      <img src="/photo.jpg" alt="Михаил Сторожилов" width="160" height="160" onerror="this.src='/photo-placeholder.svg'" />
    </div>
    <h1>Михаил Сторожилов</h1>
    <p class="role">Devrel lead · ecom.tech</p>
    <p class="tagline">
      В деврел-индустрии с 2013 года. До этого — фронтенд-разработчик. 
      Опыт консалтинга, управления деврел-командой, подготовки спикеров и организации мероприятий.
    </p>
    <a href="#about" class="cta">Подробнее обо мне</a>
  </section>

  <section id="about" class="section">
    <h2>Обо мне</h2>
    <p>
      В <strong>ecom.tech</strong> отвечаю за технический бренд работодателя. 
      Мои основные стейкхолдеры — CTO, CPO, HRD.
    </p>
    <p>
      Имею опыт консалтинга, управления деврел-командой, работы «деврелом в единственном числе», 
      подготовки спикеров, создания технического контента, организации мероприятий.
    </p>
    <h3>Мои задачи в ecom.tech</h3>
    <ul>
      <li>Разработка и реализация стратегии развития технологического бренда</li>
      <li>Продвижение технологического бренда в профессиональном сообществе</li>
      <li>Управление и развитие деврел-команды</li>
      <li>Организация и развитие внутренних ИТ-сообществ с культурой шаринга знаний</li>
      <li>Управление внутренними коммуникациями: чтобы все сотрудники имели необходимую информацию для принятия решений</li>
      <li>Помощь в найме, обучении и развитии</li>
    </ul>
  </section>

  <section id="experience" class="section">
    <h2>Опыт</h2>
    <p class="intro">
      В деврел-индустрии с 2013 года. До этого — фронтенд-разработчик.
    </p>
    <ol class="timeline">
      {timeline.map((item) => (
        <li>
          <span class="period">{item.period}</span>
          <div class="content">
            <strong>{item.role}</strong>
            {item.company && <span class="company"> · {item.company}</span>}
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section id="contacts" class="section">
    <h2>Контакты</h2>
    <p class="intro">Связаться со мной можно любым удобным способом.</p>
    <ul class="contacts">
      {contacts.map((item) => (
        <li>
          <span class="label">{item.label}</span>
          <a href={item.href} target="_blank" rel="noopener noreferrer">
            {item.value}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }

  .hero {
    text-align: center;
    padding-bottom: 4rem;
  }

  .hero-photo {
    margin-bottom: 1.5rem;
  }

  .hero-photo img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 8px 32px rgba(15, 118, 110, 0.15);
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .role {
    font-size: 1.25rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .tagline {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 6px;
  }

  .cta:hover {
    opacity: 0.9;
  }

  .section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 4rem;
  }

  #hero {
    scroll-margin-top: 4rem;
  }

  .section h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .section h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .section p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .section ul:not(.contacts):not(.timeline) {
    color: var(--color-text-muted);
    padding-left: 1.5rem;
  }

  .section ul:not(.contacts):not(.timeline) li {
    margin-bottom: 0.5rem;
  }

  .intro {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline li {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline li:last-child {
    border-bottom: none;
  }

  .period {
    flex-shrink: 0;
    width: 120px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .content {
    flex: 1;
  }

  .company {
    color: var(--color-text-muted);
  }

  .contacts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contacts li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .contacts li:last-child {
    border-bottom: none;
  }

  .label {
    flex-shrink: 0;
    width: 140px;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .contacts a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .contacts a:hover {
    text-decoration: underline;
  }
</style>
