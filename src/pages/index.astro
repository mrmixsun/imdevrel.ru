---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroContent from '../content/hero.md';
import AboutContent from '../content/about.md';
import HighlightsContent from '../content/highlights.md';
import ExperienceContent from '../content/experience.md';
import SkillsContent from '../content/skills.md';
import LanguagesContent from '../content/languages.md';
import ContactsContent from '../content/contacts.md';
---

<BaseLayout title="Михаил Сторожилов" description="Devrel lead в ecom.tech. Developer Relations с 2013 года." singlePage={true}>
  <section id="hero" class="hero">
    <div class="hero-photo">
      <img src="/photo.jpg" alt="Михаил Сторожилов" width="160" height="160" onerror="this.src='/photo-placeholder.svg'" />
    </div>
    <div class="markdown hero-markdown">
      <HeroContent />
    </div>
    <a href="#about" class="cta">Подробнее обо мне</a>
  </section>

  <section id="about" class="section">
    <div class="markdown">
      <AboutContent />
    </div>
  </section>

  <section id="highlights" class="section">
    <div class="markdown">
      <HighlightsContent />
    </div>
  </section>

  <section id="experience" class="section">
    <div class="markdown">
      <ExperienceContent />
    </div>
  </section>

  <section id="skills" class="section">
    <div class="markdown">
      <SkillsContent />
    </div>
  </section>

  <section id="languages" class="section">
    <div class="markdown">
      <LanguagesContent />
    </div>
  </section>

  <section id="contacts" class="section">
    <div class="markdown">
      <ContactsContent />
    </div>
  </section>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }

  .hero {
    text-align: center;
    padding-bottom: 4rem;
  }

  .hero-photo {
    margin-bottom: 1.5rem;
  }

  .hero-photo img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 8px 32px rgba(15, 118, 110, 0.15);
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 6px;
  }

  .cta:hover {
    opacity: 0.9;
  }

  .section {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    scroll-margin-top: 4rem;
  }

  #hero {
    scroll-margin-top: 4rem;
  }

  .markdown :global(h2) {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .hero-markdown :global(h2) {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0.25rem 0;
    letter-spacing: -0.02em;
  }

  .hero-markdown :global(p) {
    max-width: 560px;
    margin: 0 auto 1rem;
    color: var(--color-text-muted);
  }

  .hero-markdown :global(p:first-of-type) {
    color: var(--color-accent);
    font-weight: 500;
    font-size: 1.25rem;
  }

  .markdown :global(h3) {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .markdown :global(p) {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .markdown :global(ul) {
    color: var(--color-text-muted);
    padding-left: 1.5rem;
  }

  .markdown :global(li) {
    margin-bottom: 0.5rem;
  }

  .markdown :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .markdown :global(a:hover) {
    text-decoration: underline;
  }
</style>
